# ── Required ─────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# ── Owner ─────────────────────────────────────────────────
# Your Discord USER ID (right-click yourself → Copy User ID)
OWNER_ID=your_discord_user_id_here

# ── Optional ──────────────────────────────────────────────
# Groq API key — enables Alpha & Aqua AI chat
# Free at: https://console.groq.com
GROQ_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Remove.bg API key — enables .removebg command
# Free tier at: https://www.remove.bg/api
REMOVEBG_API_KEY=

# Port for the web status panel (Render sets this automatically)
PORT=3000
